# === MAX Bot ===
BOT_TOKEN=

# === PostgreSQL (в Docker compose подставится автоматически в контейнеры) ===
DATABASE_URL=postgresql://vkconf:vkconf_secret@postgres:5432/vkcloud_conf
POSTGRES_USER=vkconf
POSTGRES_PASSWORD=vkconf_secret
POSTGRES_DB=vkcloud_conf

# === Admin ===
# openssl rand -base64 48
ADMIN_JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
ADMIN_CODE_WORD=
ADMIN_CORS_ORIGIN=https://admin.example.com

# === URLs (production) ===
# Базовый URL webhook без /webhook (бот добавит /webhook сам)
WEBHOOK_URL=https://api.example.com
# Публичный URL мини-приложения (статика dist-miniapp за nginx)
MINI_APP_URL=https://app.example.com/

# === Runtime ===
PORT=3000
ADMIN_PORT=3001
NODE_ENV=production
