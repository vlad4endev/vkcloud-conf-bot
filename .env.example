# === MAX Bot ===
BOT_TOKEN=

# === PostgreSQL (в Docker compose подставится автоматически в контейнеры) ===
DATABASE_URL=postgresql://vkconf:vkconf_secret@postgres:5432/vkcloud_conf
POSTGRES_USER=vkconf
POSTGRES_PASSWORD=vkconf_secret
POSTGRES_DB=vkcloud_conf

# === Admin ===
# openssl rand -base64 48
ADMIN_JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
ADMIN_CODE_WORD=

# === URLs (production) — один домен на всё ===
# MINI_APP_URL — HTTPS URL приложения (в панели MAX: Чат-бот → мини-приложение)
# MAX_BOT_USERNAME — опционально; open_app берёт username из BOT_TOKEN автоматически
# Быстрая настройка: ./scripts/setup-domain-env.sh vkconf.skypath.fun YourBotName
WEBHOOK_URL=https://vkconf.skypath.fun
MINI_APP_URL=https://vkconf.skypath.fun/
MAX_BOT_USERNAME=
ADMIN_CORS_ORIGIN=https://vkconf.skypath.fun

# === Runtime ===
PORT=3000
ADMIN_PORT=3001
NODE_ENV=production
